@model List<EmployeeManagementPortal.Models.Employee>

<div class="container mt-5">

<h3>Employee List</h3>

<table class="table table-striped">

<tr>
<th>ID</th>
<th>Name</th>
<th>Dept</th>
</tr>

@foreach(var e in Model)
{
<tr>
<td>@e.Id</td>
<td>@e.Name</td>
<td>@e.Department</td>
</tr>
}

</table>

</div>