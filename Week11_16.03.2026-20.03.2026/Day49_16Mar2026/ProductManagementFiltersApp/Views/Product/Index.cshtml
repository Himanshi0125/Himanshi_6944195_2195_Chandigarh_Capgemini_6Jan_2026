@model List<ProductManagementFiltersApp.Models.Product>

@{
    ViewData["Title"] = "Product Management";
}

<div class="container mt-5">

<h2 class="text-primary">Product Management Dashboard</h2>

<div class="card shadow mt-4">

<div class="card-body">

<table class="table table-hover table-striped">

<thead class="table-dark">
<tr>
<th>ID</th>
<th>Product Name</th>
<th>Price</th>
</tr>
</thead>

<tbody>

@foreach(var product in Model)
{
<tr>
<td>@product.Id</td>
<td>@product.Name</td>
<td>₹@product.Price</td>
</tr>
}

</tbody>

</table>

</div>

</div>

</div>