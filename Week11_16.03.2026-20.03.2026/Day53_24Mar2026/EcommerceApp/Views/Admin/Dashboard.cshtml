<div class="container mt-4">

    <h2 class="mb-4 fw-bold">📊 Admin Dashboard</h2>

    <div class="row">

        <div class="col-md-6">
            <div class="card shadow p-3 mb-4">
                <h4 class="mb-3 text-primary">Top Selling Products</h4>

                <ul class="list-group">
                    @foreach (var item in ViewBag.TopProducts)
                    {
                        <li class="list-group-item d-flex justify-content-between align-items-center">
                            <div>
                                <strong>@item.ProductName</strong><br />
                                <small class="text-muted">ID: @item.ProductId</small>
                            </div>
                            <span class="badge bg-success">
                                Sold: @item.TotalSold
                            </span>
                        </li>
                    }
                </ul>
            </div>
        </div>

            <div class="col-md-6">
                <div class="card shadow p-3 mb-4">
                    <h4 class="mb-3 text-danger">Pending Shipments</h4>

                    @foreach (var item in ViewBag.PendingOrders)
                    {
                        <div class="border rounded p-3 mb-3">

                            <div class="d-flex justify-content-between">
                                <strong>Order ID: @item.OrderId</strong>

                                <a href="/Admin/UpdateShipping/@item.Id"
                                class="btn btn-sm btn-success">
                                    Mark Shipped
                                </a>
                            </div>

                            <hr />

                            <!-- 🔥 PRODUCT DETAILS -->
                            <ul class="mb-2">
                                @foreach (var oi in item.Order.OrderItems)
                                {
                                    <li>
                                        @oi.Product?.Name
                                        <span class="text-muted">(Qty: @oi.Quantity)</span>
                                    </li>
                                }
                            </ul>

                            <!-- OPTIONAL ADDRESS -->
                            <small class="text-muted">
                                📍 @item.Address
                            </small>

                        </div>
                    }
                </div>
            </div>
        </div>

    </div>
</div>