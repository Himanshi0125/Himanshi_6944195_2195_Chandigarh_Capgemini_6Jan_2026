@model IEnumerable<HospitalMVC.Models.Doctor>

@{
    ViewData["Title"] = "Index";
}

<h1>Doctors Index</h1>

<p>
    <a asp-action="Create">Create New</a>
</p>
<table class="table">
    <thead>
        <tr>
            <th>Doctor ID</th>
            <th>Name</th>
            <th>Specialization</th>
            <th>Total Appointments</th>
            <th></th>
        </tr>
    </thead>

<tbody>
@foreach (var item in Model)
{
    <tr>
        <td>@item.DoctorId</td>
        <td>@item.Name</td>
        <td>@item.Specialization</td>
        <td>@item.Appointments.Count()</td>
        <td>
            <a asp-action="Edit" asp-route-id="@item.DoctorId">Edit</a> |
            <a asp-action="Details" asp-route-id="@item.DoctorId">Details</a> |
            <a asp-action="Delete" asp-route-id="@item.DoctorId">Delete</a>
        </td>
    </tr>
}
</tbody>
</table>