@model IEnumerable<CompanyEmployeesApp.Models.Company>

<h2>Companies and Employees</h2>

<ul>
@foreach (var company in Model)
{
    <li>
        <strong>@company.Name</strong>

        <ul>
        @foreach (var emp in company.Employees)
        {
            <li>
                @emp.Name - @emp.Position
            </li>
        }
        </ul>

    </li>
}
</ul>